# Copy to .env and fill in real values before running
# `docker compose up --build`. Never commit the populated .env file.

# ---------------------------------------------------------------------------
# Node
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=mirakart
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mirakart
# Used by `apps/api` for local (non-docker) development only — inside
# docker-compose this is constructed automatically from the vars above.
DATABASE_URL=postgresql://mirakart:change-me@localhost:5432/mirakart

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@localhost:6379

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=mirakart
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
# Public-facing base URL for MinIO (used to build browser-accessible image URLs).
# In production set this to your public MinIO URL, e.g. https://storage.yourdomain.com
MINIO_PUBLIC_URL=http://localhost:9000
NEXT_PUBLIC_MINIO_HOST=localhost
NEXT_PUBLIC_MINIO_USE_SSL=false

# ---------------------------------------------------------------------------
# Auth (apps/api)
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
# Refresh tokens are opaque (DB-backed, hashed at rest), not JWTs — no
# separate signing secret needed. This just controls their lifetime.
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------------------------------------------------------
# Seed data (apps/api/prisma/seed.ts) — only used when running `pnpm db:seed`
# ---------------------------------------------------------------------------
SEED_SUPER_ADMIN_EMAIL=admin@mirakart.com
SEED_SUPER_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
PORT=4000
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ---------------------------------------------------------------------------
# Frontend apps (build-time + runtime)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---------------------------------------------------------------------------
# Nginx / domains (production VPS deployment)
# ---------------------------------------------------------------------------
WEB_DOMAIN=mirakart.com
ADMIN_DOMAIN=admin.mirakart.com
MERCHANT_DOMAIN=seller.mirakart.com
API_DOMAIN=api.mirakart.com
CERTBOT_EMAIL=admin@mirakart.com

# ---------------------------------------------------------------------------
# Email (transactional notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Mirakart <no-reply@mirakart.com>"

# ---------------------------------------------------------------------------
# Payments
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging (push notifications — mobile app)
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
