    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.16.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "argon2": "^0.41.1",
